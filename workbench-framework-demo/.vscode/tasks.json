{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "start-dev-server",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}", "env": {} },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:.*http"
        }
      },
      "presentation": { "reveal": "silent" }
    }
  ]
}
